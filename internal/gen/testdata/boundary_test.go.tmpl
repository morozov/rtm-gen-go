package rtm_test

import (
	"context"
	"errors"
	"net/http"
	"net/http/httptest"
	"testing"

	"example.com/rtm"
)

func TestNoArgCallHitsRTM(t *testing.T) {
	const body = `<rsp stat="ok"/>`
	var captured *http.Request
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		captured = r
		_, _ = w.Write([]byte(body))
	}))
	defer srv.Close()

	c := rtm.NewClient("test-key", "test-secret", "")
	c.BaseURL = srv.URL + "/rest/"

	got, err := c.Fixture.NoArg(context.Background())
	if err != nil {
		t.Fatalf("call failed: %v", err)
	}
	if string(got) != body {
		t.Fatalf("body mismatch: want %q, got %q", body, got)
	}
	if captured == nil {
		t.Fatalf("no request captured")
	}
	q := captured.URL.Query()
	if q.Get("method") != "rtm.fixture.noArg" {
		t.Fatalf("wrong method: %s", q.Get("method"))
	}
	if q.Get("api_key") != "test-key" {
		t.Fatalf("api_key not auto-injected, got %q", q.Get("api_key"))
	}
	if q.Get("auth_token") != "" {
		t.Fatalf("no-login method should not carry auth_token, got %q", q.Get("auth_token"))
	}
	if q.Get("api_sig") != "" {
		t.Fatalf("no-signing method should not be signed, got %q", q.Get("api_sig"))
	}
}

func TestSignedCallInjectsAuthAndSig(t *testing.T) {
	var captured *http.Request
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		captured = r
		_, _ = w.Write([]byte(`<rsp stat="ok"/>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("key", "secret", "token")
	c.BaseURL = srv.URL + "/rest/"

	_, err := c.Fixture.RequiredOnly(context.Background(), rtm.FixtureRequiredOnlyParams{
		ItemID: "123",
	})
	if err != nil {
		t.Fatalf("call failed: %v", err)
	}
	q := captured.URL.Query()
	if q.Get("auth_token") != "token" {
		t.Fatalf("auth_token missing, got %q", q.Get("auth_token"))
	}
	if q.Get("item_id") != "123" {
		t.Fatalf("item_id missing, got %q", q.Get("item_id"))
	}
	if sig := q.Get("api_sig"); len(sig) != 32 {
		t.Fatalf("api_sig should be MD5 hex (32 chars), got %q", sig)
	}
}

func TestMissingAuthTokenReturnsSentinel(t *testing.T) {
	c := rtm.NewClient("key", "secret", "")
	_, err := c.Fixture.RequiredOnly(context.Background(), rtm.FixtureRequiredOnlyParams{
		ItemID: "1",
	})
	if err == nil {
		t.Fatalf("expected error for missing auth token")
	}
	if !errors.Is(err, rtm.ErrMissingAuthToken) {
		t.Fatalf("expected ErrMissingAuthToken, got %v", err)
	}
}
