const okEmpty = `<rsp stat="ok"/>`

// TestNoArgCallHitsRTM exercises the wire side: no credentials
// required, method name set, no auth_token or api_sig.
func TestNoArgCallHitsRTM(t *testing.T) {
	var captured *http.Request
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		captured = r
		_, _ = w.Write([]byte(okEmpty))
	}))
	defer srv.Close()

	c := rtm.NewClient("test-key", "test-secret", "")
	c.BaseURL = srv.URL + "/rest/"

	if _, err := c.Fixture.NoArg(context.Background()); err != nil {
		t.Fatalf("call failed: %v", err)
	}
	q := captured.URL.Query()
	if q.Get("method") != "rtm.fixture.noArg" {
		t.Fatalf("wrong method: %s", q.Get("method"))
	}
	if q.Get("format") != "xml" {
		t.Fatalf("wrong format: %s", q.Get("format"))
	}
	if q.Get("api_key") != "test-key" {
		t.Fatalf("api_key not auto-injected, got %q", q.Get("api_key"))
	}
	if q.Get("auth_token") != "" {
		t.Fatalf("no-login method should not carry auth_token, got %q", q.Get("auth_token"))
	}
	if q.Get("api_sig") != "" {
		t.Fatalf("no-signing method should not be signed, got %q", q.Get("api_sig"))
	}
}

func TestSignedCallInjectsAuthAndSig(t *testing.T) {
	var captured *http.Request
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		captured = r
		_, _ = w.Write([]byte(`<rsp stat="ok"><item id="1" active="1" label="x"/></rsp>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("key", "secret", "token")
	c.BaseURL = srv.URL + "/rest/"

	if _, err := c.Fixture.RequiredOnly(context.Background(), rtm.FixtureRequiredOnlyParams{
		ItemID: "123",
	}); err != nil {
		t.Fatalf("call failed: %v", err)
	}
	q := captured.URL.Query()
	if q.Get("auth_token") != "token" {
		t.Fatalf("auth_token missing, got %q", q.Get("auth_token"))
	}
	if q.Get("item_id") != "123" {
		t.Fatalf("item_id missing, got %q", q.Get("item_id"))
	}
	if sig := q.Get("api_sig"); len(sig) != 32 {
		t.Fatalf("api_sig should be MD5 hex (32 chars), got %q", sig)
	}
}

func TestMissingAuthTokenReturnsSentinel(t *testing.T) {
	c := rtm.NewClient("key", "secret", "")
	_, err := c.Fixture.RequiredOnly(context.Background(), rtm.FixtureRequiredOnlyParams{
		ItemID: "1",
	})
	if err == nil {
		t.Fatalf("expected error for missing auth token")
	}
	if !errors.Is(err, rtm.ErrMissingAuthToken) {
		t.Fatalf("expected ErrMissingAuthToken, got %v", err)
	}
}

// TestTypedResponseCoercesValues walks the full flow: stringly-
// typed XML attributes are unmarshalled into typed Go fields. The
// fixture method rtm.fixture.requiredOnly has item.id and
// item.active in typeTable, so the generated response struct
// carries rtmInt and rtmBool fields respectively. item.label is
// absent from typeTable, so it stays a plain string.
func TestTypedResponseCoercesValues(t *testing.T) {
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		_, _ = w.Write([]byte(`<rsp stat="ok"><item id="42" active="1" label="demo"/></rsp>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("k", "s", "token")
	c.BaseURL = srv.URL + "/rest/"

	got, err := c.Fixture.RequiredOnly(context.Background(), rtm.FixtureRequiredOnlyParams{ItemID: "1"})
	if err != nil {
		t.Fatalf("call failed: %v", err)
	}
	if got.Item.ID != 42 {
		t.Fatalf("id wire %q should coerce to rtmInt(42), got %d", "42", got.Item.ID)
	}
	if !bool(got.Item.Active) {
		t.Fatalf("active wire %q should coerce to rtmBool(true), got %v", "1", got.Item.Active)
	}
	if got.Item.Label != "demo" {
		t.Fatalf("label should round-trip as string, got %q", got.Item.Label)
	}
}

// TestTypedResponseAcceptsEmptyScalars exercises the rtmInt/rtmBool
// empty-string short-circuit. RTM emits "" for absent integer or
// boolean attributes; the typed wrappers must decode that as a
// zero value rather than failing the whole response.
func TestTypedResponseAcceptsEmptyScalars(t *testing.T) {
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		_, _ = w.Write([]byte(`<rsp stat="ok"><item id="" active="" label="demo"/></rsp>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("k", "s", "token")
	c.BaseURL = srv.URL + "/rest/"

	got, err := c.Fixture.RequiredOnly(context.Background(), rtm.FixtureRequiredOnlyParams{ItemID: "1"})
	if err != nil {
		t.Fatalf("call failed on empty scalars: %v", err)
	}
	if got.Item.ID != 0 {
		t.Fatalf("empty id should decode to 0, got %d", got.Item.ID)
	}
	if bool(got.Item.Active) {
		t.Fatalf("empty active should decode to false, got %v", got.Item.Active)
	}
}

// TestEmptyContainerDecodesAsEmpty verifies that a self-closing
// container element decodes as a non-nil empty slice (so JSON
// marshals the field as `[]`, not `null` or absent), not a
// decode error.
func TestEmptyContainerDecodesAsEmpty(t *testing.T) {
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		_, _ = w.Write([]byte(`<rsp stat="ok"><items/></rsp>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("k", "s", "")
	c.BaseURL = srv.URL + "/rest/"

	got, err := c.Fixture.EmptyContainer(context.Background())
	if err != nil {
		t.Fatalf("call failed: %v", err)
	}
	if len(got.Items) != 0 {
		t.Fatalf("expected 0 items, got %d", len(got.Items))
	}
	if got.Items == nil {
		t.Fatal("expected non-nil empty slice so JSON marshals as []")
	}
	raw, err := json.Marshal(got)
	if err != nil {
		t.Fatalf("marshal: %v", err)
	}
	if string(raw) != `{"items":[]}` {
		t.Fatalf("expected {\"items\":[]}, got %s", raw)
	}
}

// TestMissingContainerDecodesAsEmpty verifies the empty-list
// invariant when RTM omits the container element entirely
// instead of self-closing it.
func TestMissingContainerDecodesAsEmpty(t *testing.T) {
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		_, _ = w.Write([]byte(`<rsp stat="ok"/>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("k", "s", "")
	c.BaseURL = srv.URL + "/rest/"

	got, err := c.Fixture.EmptyContainer(context.Background())
	if err != nil {
		t.Fatalf("call failed: %v", err)
	}
	if got.Items == nil || len(got.Items) != 0 {
		t.Fatalf("expected non-nil empty slice, got %#v", got.Items)
	}
	raw, err := json.Marshal(got)
	if err != nil {
		t.Fatalf("marshal: %v", err)
	}
	if string(raw) != `{"items":[]}` {
		t.Fatalf("expected {\"items\":[]}, got %s", raw)
	}
}

// TestEmptyContainerDecodesPopulated verifies that the same
// method decodes a populated container correctly. The collection
// wrapper `<items><item/>…</items>` flattens in Go to a plain
// []struct{...}: callers write got.Items[i], not got.Items.Item[i].
func TestEmptyContainerDecodesPopulated(t *testing.T) {
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		_, _ = w.Write([]byte(`<rsp stat="ok"><items><item id="7" label="a"/><item id="8" label="b"/></items></rsp>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("k", "s", "")
	c.BaseURL = srv.URL + "/rest/"

	got, err := c.Fixture.EmptyContainer(context.Background())
	if err != nil {
		t.Fatalf("call failed: %v", err)
	}
	if len(got.Items) != 2 {
		t.Fatalf("expected 2 items, got %d", len(got.Items))
	}
	if got.Items[0].Label != "a" || got.Items[1].Label != "b" {
		t.Fatalf("items decoded incorrectly: %+v", got.Items)
	}
}

func TestAPIErrorReturnsTypedError(t *testing.T) {
	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, _ *http.Request) {
		_, _ = w.Write([]byte(`<rsp stat="fail"><err code="98" msg="Login failed / Invalid auth token"/></rsp>`))
	}))
	defer srv.Close()

	c := rtm.NewClient("k", "s", "")
	c.BaseURL = srv.URL + "/rest/"

	_, err := c.Fixture.NoArg(context.Background())
	if err == nil {
		t.Fatal("expected error on stat=fail")
	}
	if !errors.Is(err, rtm.ErrRTMAPI) {
		t.Fatalf("expected ErrRTMAPI wrap, got %v", err)
	}
	var apiErr *rtm.APIError
	if !errors.As(err, &apiErr) {
		t.Fatalf("expected *APIError, got %T", err)
	}
	if apiErr.Code != 98 {
		t.Fatalf("expected code 98, got %d", apiErr.Code)
	}
	if apiErr.Message == "" {
		t.Fatal("expected non-empty message")
	}
}
